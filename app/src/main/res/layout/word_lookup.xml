<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <EditText
                android:id="@+id/edit_lookup_word"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/word_back"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:ems="15"
                android:fontFamily="monospace"
                android:importantForAutofill="no"
                android:inputType="textNoSuggestions|text"
                android:padding="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textAllCaps="true"
                android:textSize="24sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="8sp" />

            <TableRow
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end">

                <Button
                    android:id="@+id/button_lookup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Lookup"
                    android:textSize="24sp" />
            </TableRow>

            <Space
                android:layout_width="match_parent"
                android:layout_height="16sp" />

            <ProgressBar
                android:id="@+id/lookup_loading"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:minWidth="40dp"
                android:minHeight="40dp"
                android:visibility="gone"
                tools:visibility="visible" />

            <TableRow
                android:id="@+id/lookup_meaning_header_row_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="40sp"
                    android:layout_height="wrap_content"
                    android:paddingEnd="8sp"
                    android:text="1."
                    android:textAlignment="textEnd"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lookup_meaning_type_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_definition_row_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/lookup_meaning_definition_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="40sp"
                    android:textSize="24sp" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_header_row_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8sp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="40sp"
                    android:layout_height="wrap_content"
                    android:paddingEnd="8sp"
                    android:text="2."
                    android:textAlignment="textEnd"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lookup_meaning_type_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_definition_row_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/lookup_meaning_definition_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="40sp"
                    android:textSize="24sp" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_header_row_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8sp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="40sp"
                    android:layout_height="wrap_content"
                    android:paddingEnd="8sp"
                    android:text="3."
                    android:textAlignment="textEnd"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lookup_meaning_type_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_definition_row_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/lookup_meaning_definition_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="40sp"
                    android:textSize="24sp" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_header_row_4"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8sp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="40sp"
                    android:layout_height="wrap_content"
                    android:paddingEnd="8sp"
                    android:text="4."
                    android:textAlignment="textEnd"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lookup_meaning_type_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_definition_row_4"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/lookup_meaning_definition_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="40sp"
                    android:textSize="24sp" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_header_row_5"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8sp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="40sp"
                    android:layout_height="wrap_content"
                    android:paddingEnd="8sp"
                    android:text="5."
                    android:textAlignment="textEnd"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/lookup_meaning_type_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </TableRow>

            <TableRow
                android:id="@+id/lookup_meaning_definition_row_5"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/lookup_meaning_definition_5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="40sp"
                    android:textSize="24sp" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_see_also_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8sp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8sp"
                    android:text="See:"
                    android:textSize="24sp"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/lookup_see_also"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="OTHER OTHER"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_error_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sorry, an error occurred looking up the word (maybe you don't have internet connection?)"
                    android:textAlignment="center"
                    android:textColor="@color/error"
                    android:textSize="24sp"
                    android:textStyle="italic" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_not_found_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sorry, that word does not exist in my dictionary"
                    android:textAlignment="center"
                    android:textColor="@color/error"
                    android:textSize="24sp"
                    android:textStyle="italic" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_not_found_404_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sorry, that word does exists in my dictionary but not in the online dictionary"
                    android:textAlignment="center"
                    android:textColor="@color/error"
                    android:textSize="24sp"
                    android:textStyle="italic" />
            </TableRow>

            <TableRow
                android:id="@+id/lookup_offensive_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Word exists in dictionary - but the meaning is offensive or derogatory"
                    android:textAlignment="center"
                    android:textSize="24sp"
                    android:textStyle="italic" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=" "/>
            </TableRow>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>