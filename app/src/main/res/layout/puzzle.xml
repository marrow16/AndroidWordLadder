<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/puzzle_header_area"
        android:layout_width="match_parent"
        android:layout_height="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:shrinkColumns="1"
            android:stretchColumns="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/previous_solution_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="48sp"
                    android:layout_height="48sp"
                    android:padding="0dp"
                    android:visibility="invisible"
                    app:icon="@drawable/left_arrow"
                    app:iconGravity="start" />

                <TextView
                    android:id="@+id/puzzle_header"
                    android:layout_width="match_parent"
                    android:layout_height="48sp"
                    android:layout_margin="0sp"
                    android:text="@string/empty_text_solutions"
                    android:textAlignment="center"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/next_solution_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="48sp"
                    android:layout_height="48sp"
                    android:padding="0dp"
                    app:icon="@drawable/right_arrow"
                    app:iconGravity="end" />
            </TableRow>
        </TableLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        layout="@layout/puzzle_ladder"
        android:id="@+id/puzzle_ladder_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <include
        layout="@layout/solution_ladder"
        android:id="@+id/solution_ladder_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>